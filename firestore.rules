rules_version = '2';
// Déploiement : firebase deploy --only firestore:rules
// firebase.json cible la base nommée (même id que firestoreDatabaseId dans firebase-applet-config.json).
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /**
     * Admin, par priorité :
     * 1) UID Firebase Auth du compte principal (chinois2001@gmail.com)
     * 2) Doc admin_allowlist/{auth.uid} (console / Admin SDK)
     * 3) Email sur le token (trim)
     * 4) users/{uid}.role == admin
     */
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == 'HiSztwqyDXUZ5RalOyqUP3BJd6Y2' ||
        exists(/databases/$(database)/documents/admin_allowlist/$(request.auth.uid)) ||
        (request.auth.token.email is string &&
          request.auth.token.email.trim() == 'chinois2001@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Validation minimale : champs obligatoires uniquement
    // Les champs optionnels (positionCategory, keywords, highlightedNeeds, etc.)
    // sont acceptés sans restriction pour ne pas bloquer l'enregistrement du profil.
    /** uid dans le document doit correspondre à l’id du doc users/{userId} (propriétaire ou admin qui édite). */
    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'fullName', 'companyName', 'email', 'role', 'createdAt'])
        && data.uid is string
        && data.uid == userId
        && data.fullName is string && data.fullName.size() >= 1
        && data.companyName is string && data.companyName.size() >= 1
        && data.email is string
        && data.role in ['user', 'admin']
        && data.createdAt is timestamp;
    }

    function isValidNeedComment(data) {
      return data.keys().hasAll(['needId', 'authorId', 'authorName', 'authorPhoto', 'text', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.authorName is string
        && data.authorPhoto is string
        && data.text is string && data.text.size() <= 500
        && data.createdAt is number;
    }

    function isValidRecommendation(data) {
      return data.keys().hasAll(['profileId', 'authorId', 'authorName', 'authorPhoto', 'text', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.authorName is string
        && data.authorPhoto is string
        && data.text is string && data.text.size() <= 200
        && data.createdAt is number;
    }

    /**
     * Demandes réseau (annonce publique, pas de modération avant publication).
     * Champs numériques : timestamps en ms (cohérent avec need_comments / recommendations).
     */
    function isValidMemberNetworkRequest(data) {
      return data.keys().hasAll([
          'authorId', 'authorName', 'authorPhoto', 'authorCompany', 'text', 'zone', 'productOrService',
          'createdAt', 'expiresAt'
        ])
        && data.authorId == request.auth.uid
        && data.authorName is string && data.authorName.size() >= 1 && data.authorName.size() <= 200
        && data.authorPhoto is string && data.authorPhoto.size() <= 2048
        && data.authorCompany is string && data.authorCompany.size() <= 200
        && data.text is string && data.text.size() >= 1 && data.text.size() <= 800
        && data.zone is string && data.zone.size() >= 1 && data.zone.size() <= 200
        && data.productOrService is string && data.productOrService.size() >= 1 && data.productOrService.size() <= 200
        && data.createdAt is number
        && data.expiresAt is number
        && data.expiresAt > data.createdAt
        && data.expiresAt - data.createdAt <= 7776000000
        && (!('textTranslations' in data) || (
          data.textTranslations is map
          && data.textTranslations.keys().hasOnly(['fr', 'es', 'en'])
          && (!('fr' in data.textTranslations) || (data.textTranslations.fr is string && data.textTranslations.fr.size() <= 1200))
          && (!('es' in data.textTranslations) || (data.textTranslations.es is string && data.textTranslations.es.size() <= 1200))
          && (!('en' in data.textTranslations) || (data.textTranslations.en is string && data.textTranslations.en.size() <= 1200))
        ))
        && (!('sector' in data) || (data.sector is string && data.sector.size() >= 1 && data.sector.size() <= 200));
    }

    /** Besoins analytics (dashboard) : création par le membre concerné uniquement. */
    function isValidMemberNeed(data) {
      return data.keys().hasAll(['memberId', 'sector', 'need', 'createdAt'])
        && data.memberId is string
        && data.sector is string && data.sector.size() >= 1 && data.sector.size() <= 200
        && data.need in ['sourcing', 'partners', 'recruitment', 'visibility', 'softlanding', 'legal']
        && data.createdAt is timestamp;
    }

    /** Connexions OAuth sans obligation de fiche annuaire — écriture par le propriétaire, lecture admin. */
    function isValidAuthLead(data, userId) {
      return data.keys().hasOnly([
          'uid', 'email', 'displayName', 'photoURL', 'primaryProvider',
          'emailVerified', 'firstConnectedAt', 'lastConnectedAt'
        ])
        && data.uid is string && data.uid == userId
        && data.email is string && data.email.size() <= 320
        && data.displayName is string && data.displayName.size() <= 300
        && data.photoURL is string && data.photoURL.size() <= 2048
        && data.primaryProvider is string && data.primaryProvider.size() <= 64
        && data.emailVerified is bool
        && data.firstConnectedAt is timestamp
        && data.lastConnectedAt is timestamp;
    }

    /** Tracking de clics / interactions UI (lecture admin uniquement). */
    function isValidEventLog(data) {
      return data.keys().hasOnly([
          'eventType', 'actorUid', 'actorEmail', 'targetId', 'targetType', 'source', 'metadata', 'createdAt'
        ])
        && data.eventType is string && data.eventType.size() >= 1 && data.eventType.size() <= 64
        && (!('actorUid' in data) || data.actorUid is string || data.actorUid == null)
        && (!('actorEmail' in data) || data.actorEmail is string || data.actorEmail == null)
        && (!('targetId' in data) || data.targetId is string || data.targetId == null)
        && (!('targetType' in data) || data.targetType is string)
        && (!('source' in data) || data.source is string)
        && (!('metadata' in data) || data.metadata is map)
        && data.createdAt is timestamp;
    }

    /** Données non publiques (genre, nationalité, délégations, sponsoring) : propriétaire + admin uniquement. */
    function isValidUserAdminPrivate(data, userId) {
      return data.uid == userId
        && (!('genderStat' in data) || data.genderStat in ['male', 'female', 'other', 'prefer_not_say'])
        && (!('nationality' in data) || (data.nationality is string && data.nationality.size() >= 2 && data.nationality.size() <= 3))
        && (!('acceptsDelegationVisits' in data) || data.acceptsDelegationVisits is bool)
        && (!('openToEventSponsoring' in data) || data.openToEventSponsoring is bool);
    }

    match /user_admin_private/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin())
        && isValidUserAdminPrivate(request.resource.data, userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
      // Lecture ouverte : l’app limite l’affichage invité (4 fiches, nom + société seuls nets).
      // Pour empêcher techniquement l’extraction des champs sensibles, il faudrait une collection
      // « public » ou Cloud Functions (Firestore ne masque pas des champs par règle sur un même doc).
      allow read: if true;

      allow create: if isAuthenticated()
        && isOwner(userId)
        && isValidUser(request.resource.data, userId)
        && (request.resource.data.role == 'user' || isAdmin());

      // Seul un admin peut modifier le champ `role` (promouvoir / rétrograder).
      // Un membre peut mettre à jour son profil mais pas s’attribuer le rôle admin.
      allow update: if isAuthenticated()
        && isValidUser(request.resource.data, userId)
        && request.resource.data.uid == resource.data.uid
        && (
          isAdmin()
          || (
            isOwner(userId)
            && request.resource.data.role == resource.data.role
          )
        );

      allow delete: if isOwner(userId) || isAdmin();
    }

    match /need_comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidNeedComment(request.resource.data);
      allow delete: if isAuthenticated()
        && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /recommendations/{recId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidRecommendation(request.resource.data);
      allow delete: if isAuthenticated()
        && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /member_requests/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidMemberNetworkRequest(request.resource.data);
      allow update: if false;
      allow delete: if isAuthenticated()
        && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /member_needs/{docId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && isValidMemberNeed(request.resource.data)
        && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && (resource.data.memberId == request.auth.uid || isAdmin());
    }

    match /auth_leads/{userId} {
      allow read: if isAdmin();
      allow create, update: if isOwner(userId) && isValidAuthLead(request.resource.data, userId);
      allow delete: if isAdmin();
    }

    match /events_log/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidEventLog(request.resource.data);
      allow update, delete: if isAdmin();
    }

    /**
     * Admins : un document par UID Firebase Auth, ID du doc = même chaîne que l’UID (création / suppression
     * uniquement depuis la console ou Admin SDK). L’app cliente ne peut pas lire ni écrire cette collection.
     */
    match /admin_allowlist/{uid} {
      allow read, write: if false;
    }
  }
}
