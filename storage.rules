rules_version = '2';
// L’app n’utilise plus Firebase Storage côté client (pas d’uploadBytes / getDownloadURL).
// Les photos de profil sont des URL externes. Écriture désactivée ; lecture laissée pour
// d’éventuels fichiers historiques sous profile_avatars/.
service firebase.storage {
  match /b/{bucket}/o {
    match /profile_avatars/{userId} {
      allow read: if true;
      allow write, delete: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
