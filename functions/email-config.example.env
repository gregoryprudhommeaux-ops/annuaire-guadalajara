# Copier dans functions/.env (à côté des paramètres Google Sheet existants).

# Clé API Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Adresse expéditeur (le domaine doit être vérifié dans Resend → SPF/DKIM)
