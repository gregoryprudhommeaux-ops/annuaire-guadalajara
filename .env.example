# Gemini (Vite) : copier les variables utiles vers .env.local — ne jamais commiter de vraie clé.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# URL publique du site (liens d’invitation → …/join). En build production, défaut : https://www.franconetwork.app
# Surcharge optionnelle (staging, preview) :
# VITE_PUBLIC_SITE_URL="https://www.franconetwork.app"

# GEMINI_API_KEY: alternative Node / hors Vite.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Formulaire Contact (Vercel uniquement, pas de préfixe VITE_) ---
# Resend : https://resend.com — créer une clé API, vérifier un domaine d’envoi si besoin.
RESEND_API_KEY="re_xxxxxxxx"
# Boîte qui reçoit les messages (jamais affichée sur le site ; à définir dans le tableau de bord Vercel).
CONTACT_TO_EMAIL="your-inbox@example.com"
# Expéditeur vu par le destinataire (domaine vérifié chez Resend, ex. Annuaire <contact@votredomaine.com>).
CONTACT_FROM_EMAIL="Annuaire Guadalajara <onboarding@resend.dev>"

# Optionnel : en local (npm run dev), pointer vers l’URL du déploiement qui expose /api/contact
# VITE_CONTACT_API_URL="https://franconetwork.app"
